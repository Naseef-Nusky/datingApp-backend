# Server
NODE_ENV=development
PORT=5000

# Backend URL (used in auth callbacks; no trailing slash)
BACKEND_URL=http://localhost:5000

# Frontend & CRM (for CORS and links in emails)
# Production server: FRONTEND_URL=https://vantagedating.com
# Local dev: when BACKEND_URL is localhost, login/email links use LOCAL_FRONTEND_URL (default http://localhost:3000 — Vite dev port)
FRONTEND_URL=https://vantagedating.com
LOCAL_FRONTEND_URL=http://localhost:3000
# Local dev: email links use LOCAL_FRONTEND_URL when BACKEND_URL is localhost (or NODE_ENV=development)
# Force localhost links on a remote API: EMAIL_FORCE_LOCAL_LINKS=1
# EMAIL_FRONTEND_URL=https://vantagedating.com

# Mobile app (Capacitor) — separate API prefix, same handlers as /api/*
# Mobile client calls /api/mobile/auth, /api/mobile/profiles, etc.
# Web app continues using /api/* unchanged.
# GET /api/mobile/config — mobile feature flags
# GET /api/mobile/health — mobile health check
# IOS_APP_LOGIN_SCHEME=com.vantagedating.app
# Optional: Admin CRM URL (allowed CORS origin)
# CRM_URL=http://localhost:5174

# Or set comma-separated list of allowed origins instead.
# PRODUCTION: You must allow BOTH app and CRM, e.g.:
#   CORS_ORIGINS=https://app.vantagedating.com,https://crm.vantagedating.com
# If only CRM is listed, requests from app.vantagedating.com will be blocked by CORS.
# CORS_ORIGINS=https://app.yourdomain.com,https://crm.yourdomain.com

# If your proxy/CDN already adds CORS headers, set this to avoid duplicate header errors:
# Production only: if nginx/Cloudflare already sends CORS, set NODE_ENV=production AND PROXY_HANDLES_CORS=1.
# Do not use locally or the API will return no CORS headers and the browser will block localhost frontends.
# If PROXY_HANDLES_CORS=1, nginx must add CORS for Capacitor mobile too (Origin: capacitor://localhost, ionic://localhost).
# PROXY_HANDLES_CORS=1

# Log blocked CORS origins to server console (debug mobile / nginx issues)
# DEBUG_CORS=1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datingapp
DB_USER=postgres
DB_PASSWORD=

# --- Local dev (recommended when your home IP changes often) ---
# 1. npm run db:local          → starts Docker Postgres on localhost:5432
# 2. Set in .env:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=datingapp
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false
# No DigitalOcean firewall / IP whitelist needed for local dev.

# Digital Ocean Managed Database (or any remote PostgreSQL with SSL)
# Uncomment and set when using a hosted cluster (e.g. vantage-dating-db)
# DB_HOST=vantage-dating-db-do-user-XXXXX.k.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=defaultdb
# DB_USER=doadmin
# DB_PASSWORD=your_password_from_do_control_panel
# DB_SSL=true
# Optional: path to CA cert (download from DO → Connection details)
# DB_SSL_CA=./ca-certificate.crt
#
# ETIMEDOUT from your Mac? DO blocks unknown IPs in "Trusted Sources".
# When your public IP changes (Wi‑Fi, router restart, VPN):
#   npm run db:allow-my-ip
# Requires once in .env:
#   DIGITALOCEAN_API_TOKEN=...        (https://cloud.digitalocean.com/account/api/tokens)
#   DO_DB_CLUSTER_ID=...              (UUID from DO → Databases → your cluster URL)
#
# Production fix (permanent): run the API on a DO Droplet in the same VPC as the DB
# (server IP is stable; add the Droplet to Trusted Sources once).

# Optional: connection retry / pool tuning (remote DB)
# DB_CONNECT_RETRIES=5
# DB_CONNECT_RETRY_DELAY_MS=4000
# DB_CONNECT_TIMEOUT_MS=20000
# DB_POOL_ACQUIRE_MS=60000

# Optional: force schema sync on startup
# SYNC_DB=false

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Email – SendGrid (all app email: sign-in, notifications, CRM)
# Dashboard checklist (https://app.sendgrid.com):
#   1. Settings → Sender Authentication → Domain Authentication → vantagedating.com = Verified
#   2. Settings → Tracking → Click Tracking = OFF, Open Tracking = OFF
#   3. FROM address must match verified domain (e.g. notifications@vantagedating.com)
#   4. DNS: add DMARC TXT on _dmarc.vantagedating.com (recommended)
#   5. Upgrade off Trial for production (shared IPs hurt dating-app deliverability)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notifications@vantagedating.com
SENDGRID_FROM_NAME=Vantage Dating
SENDGRID_REPLY_TO=support@vantagedating.com
SUPPORT_EMAIL=support@vantagedating.com
TRANSACTIONAL_EMAIL_PROVIDER=sendgrid
SENDGRID_CLICK_TRACKING=false
# SENDGRID_LOGIN_TEXT_ONLY=true
# Dedicated IP pool — use only after IP warmup (cold dedicated IP often lands in Junk)
# Dedicated IP pool for transactional mail (reduces spam folder placement)
SENDGRID_IP_POOL_NAME=vantage-safe-transactional
# SENDGRID_DEDICATED_IP_WARMED=true
# ENABLE_NEW_USER_STREAMER_EMAIL=false
# PAUSE_MARKETING_EMAILS=true
# Mobile app — compatibility match emails (mobile users only; hourly check, send when top 3 changes)
# ENABLE_MOBILE_COMPATIBILITY_EMAIL=false
# MOBILE_COMPAT_EMAIL_CRON=0 * * * *
# MOBILE_COMPAT_EMAIL_MIN_SCORE=0
# MOBILE_COMPAT_EMAIL_MAX_MATCHES=3
# MOBILE_COMPAT_EMAIL_MIN_HOURS=1
# Same as FRONTEND_URL if the app and website share one domain (e.g. https://vantagedating.com)
# MOBILE_APP_WEB_URL=https://vantagedating.com
# Universal Links — https links open the iOS app when installed (see /.well-known/apple-app-site-association)
# MOBILE_UNIVERSAL_LINKS_ENABLED=true
# APPLE_TEAM_ID=XXXXXXXXXX
# IOS_APP_BUNDLE_ID=com.vantagedating.app
# IOS_APP_LOGIN_SCHEME=com.vantagedating.app
# MOBILE_UNIVERSAL_LINK_HOSTS=app.vantagedating.com,vantagedating.com
# ANDROID_APP_PACKAGE=com.vantagedating.app
# ANDROID_APP_SHA256_CERT=
# If Node errors "unable to verify the first certificate" to api.sendgrid.com (proxy/AV SSL scan on Windows):
# Prefer: NODE_EXTRA_CA_CERTS=C:\path\to\corp-ca.pem
# Or SendGrid HTTPS only: SENDGRID_TLS_REJECT_UNAUTHORIZED=false
# EMAIL_LOGO_URL=https://vantagedating.com/logo.jpeg
# SENDGRID_LOGO_URL=https://vantagedating.com/logo.jpeg
# PUBLIC_LOGO_URL=

# Email – SMTP fallback
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Vantage Dating
# EMAIL_GIFT_BANNER_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple (native iOS identity token — POST /api/auth/apple)
# JWT audience must match your iOS bundle ID (default com.vantagedating.app).
# APPLE_BUNDLE_ID=com.vantagedating.app
# Optional: also accept a Services ID audience (web / future).
# APPLE_SERVICES_ID=

# App Store review demo user (password login). Run after deploy: npm run create-review-user
# REVIEW_USER_EMAIL=review@vantagedating.com
# REVIEW_USER_PASSWORD=

# Google Cloud Translation API (for site language dropdown – whole site translate)
# Enable Cloud Translation API in Google Cloud Console, create an API key, set here.
# If not set, non-English languages will fall back to English.
# GOOGLE_TRANSLATE_API_KEY=

# OpenAI — AI compatibility scores (GET /api/compatibility/with/:id, POST /api/compatibility/batch)
# If unset, the API uses a heuristic fallback (no AI call).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# DigitalOcean Spaces (optional; for uploads)
# DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_NAME=
# DO_SPACES_REGION=nyc3
# If uploads fail with UNABLE_TO_VERIFY_LEAF_SIGNATURE (local proxy/AV): prefer NODE_EXTRA_CA_CERTS=...pem
# Or Spaces-only: DO_SPACES_TLS_REJECT_UNAUTHORIZED=false

# Stripe (upgrade / subscription payments) – only secret key required
# Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# Optional: webhook secret (for checkout.session.completed). If omitted, payment is confirmed on success redirect via confirm-payment.
# STRIPE_WEBHOOK_SECRET=whsec_...

# Agora (optional; video/voice/chat)
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=
# AGORA_APP_KEY=
# AGORA_CHAT_REST_HOST=a71.chat.agora.io

# Admin user (for scripts: createAdmin.js, updateToSuperAdmin.js)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User
